{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__apdf__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) $TOOL_NAME\" >> \"$CLAUDE_PROJECT_DIR\"/.apdf/session.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-awareness.sh"
          }
        ]
      }
    ]
  }
}
