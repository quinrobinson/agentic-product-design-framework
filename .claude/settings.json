{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__apdf__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/persist-artifact.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__apdf__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-context.sh"
          }
        ]
      }
    ]
  }
}
